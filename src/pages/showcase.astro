---
//
//  showcase.astro
//  CV Hub
//
//  Created by Alexander Gusarov on 03.03.2026.
//  @spartan121
//
import { getEntry } from 'astro:content';
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const lang = Astro.url.searchParams.get('lang') || 'en';

const t = {
  title: lang === 'ru' ? 'Проекты' : 'Showcase',
  empty:
    lang === 'ru'
      ? 'Здесь пока ничего.'
      : 'No projects yet.',
};

// projects.yaml лежит в коллекции showcase, entry id = 'projects'
let projects = [];

try {
  const entry = await getEntry('showcase', 'projects');
  projects = entry?.data?.projects ?? [];
} catch (err) {
  console.warn('Showcase collection or entry not found. Rendering empty showcase.');
  projects = [];
}

projects = Array.isArray(projects) ? projects : [];
projects = [...projects].sort((a, b) => {
  const af = a?.featured ? 1 : 0;
  const bf = b?.featured ? 1 : 0;
  if (af !== bf) return bf - af;
  const an = String(a?.name ?? '').toLowerCase();
  const bn = String(b?.name ?? '').toLowerCase();
  return an.localeCompare(bn);
});
---

<Layout title={lang === 'ru' ? 'Проекты' : 'Projects'} lang={lang} section="showcase">
  <section class="container">
    <header class="showcase__header">
      <h1>{t.title}</h1>
      <p class="muted">{t.subtitle}</p>
    </header>

    {projects.length > 0 ? (
      <div class="grid">
        {projects.map((p) => (
          <ProjectCard project={p} />
        ))}
      </div>
    ) : (
      <article class="card">
        <p class="muted">{t.empty}</p>
      </article>
    )}

    <style>
      .showcase__header { margin-bottom: 14px; }
      .showcase__header h1 { margin: 0; }
      .showcase__header p { margin: 8px 0 0; }
    </style>
  </section>
</Layout>