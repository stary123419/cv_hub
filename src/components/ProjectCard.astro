---
//
// ProjectCard.astro
// CV Hub
// Updated to support extended showcase schema
//
const { project } = Astro.props;

// NOTE: use strict booleans, because content schemas may default missing flags to false
const featured = project?.featured === true;
// Support both keys: `archived` and legacy `archive`
const archivedFlag = project?.archived === true || project?.archive === true;
// featured has priority: if featured=true, ignore archived behavior
const isArchived = archivedFlag && !featured;

const title = project?.name ?? 'Untitled';
const role = project?.role ?? '';
const year = project?.year ?? '';
const desc = project?.description ?? '';

const theme = project?.theme ?? 'blue';
const accent = project?.accent ?? null;

const stack = project?.stack ?? [];
const tags = project?.tags ?? [];
const platforms = project?.platforms ?? [];
const metrics = project?.metrics ?? [];
const links = project?.links ?? [];
const media = project?.media ?? [];

// GitHub Pages can serve the site under a base path (e.g. /cv_hub/).
// YAML usually uses absolute-like paths (/media/...). Prefix BASE_URL for local assets.
const withBase = (p = '') => {
  const s = String(p);
  if (!s) return '';
  // keep absolute URLs and data URIs untouched
  if (/^(https?:)?\/\//i.test(s) || s.startsWith('data:')) return s;
  const clean = s.replace(/^\/+/, '');
  const base = String(import.meta.env.BASE_URL || '/');
  const baseNorm = base.endsWith('/') ? base : `${base}/`;
  return `${baseNorm}${clean}`;
};

const featuredMedia = media.find((m) => m.featured) ?? media[0] ?? null;

// Inline style override if accent HEX is provided
const accentStyle = accent ? `--card-accent: ${accent};` : '';
---

{isArchived ? (
  <article
    class={`card project project--${theme} project--archived is-collapsed ${media.length === 0 ? 'project--no-media' : ''}`}
    style={accentStyle}
    data-archived="1"
  >
    <button
      class="project__toggle"
      type="button"
      aria-expanded="false"
      aria-label="Toggle archived project"
    >
      <span class="project__toggle-icon" aria-hidden="true">
        <svg class="project__toggle-svg" viewBox="0 0 24 24" width="16" height="16" focusable="false">
          <path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </button>

    <!-- Archived card renders ONE header + ONE Platforms row.
         The rest of the content is in .project__details and is simply hidden when collapsed. -->
    <header class="card__header project__compact">
      <div>
        {(role || year) && (
          <div class="card__meta">
            {role && <span class="muted">{role}</span>}
            {year && <span class="muted">{role ? '· ' : ''}{year}</span>}
          </div>
        )}
        <h2 class="card__title">{title}</h2>
      </div>
    </header>

    <div class="project__details project__details-top">
      {featuredMedia && (
        <div class="media">
          {featuredMedia.type === 'video' && (
            <video
              class="media__el"
              src={withBase(featuredMedia.src)}
              controls
              playsinline
              preload="metadata"
            ></video>
          )}

          {(featuredMedia.type === 'image' || featuredMedia.type === 'gif') && (
            <img
              class="media__el"
              src={withBase(featuredMedia.src)}
              alt={featuredMedia.alt ?? ''}
              loading="lazy"
              onerror="this.closest('.media')?.remove();"
            />
          )}

          {media.length > 1 && (
            <div class="thumbs" aria-label="Project media">
              {media.map((m, idx) => (
                <a
                  class={`thumb ${m === featuredMedia ? 'thumb--active' : ''}`}
                  href={withBase(m.src)}
                  target="_blank"
                  rel="noopener"
                  title={m.alt ?? `Media ${idx + 1}`}
                >
                  {(m.type === 'image' || m.type === 'gif') && (
                    <img
                      class="thumb__img"
                      src={withBase(m.src)}
                      alt={m.alt ?? ''}
                      loading="lazy"
                      onerror="this.closest('.thumb')?.remove();"
                    />
                  )}
                  {m.type === 'video' && (
                    <div class="thumb__video">▶</div>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      )}

      {desc && <p class="card__desc">{desc}</p>}

      {metrics.filter((m) => m?.label || m?.value).length > 0 && (
        <div class="metrics-grid">
          {metrics
            .filter((m) => m?.label || m?.value)
            .map((m) => (
              <div class="metric-card">
                {m.label && <div class="metric-label">{m.label}</div>}
                {m.value && <div class="metric-value">{m.value}</div>}
              </div>
            ))}
        </div>
      )}
    </div>

    <div class="row project__compact-platforms">
      <div class="row__title">Platforms</div>
      <ul class="tags">
        {platforms.filter(Boolean).map((p) => <li class="tag">{p}</li>)}
      </ul>
    </div>

    <div class="project__details project__details-bottom">
      {stack.length > 0 && (
        <div class="row">
          <div class="row__title">Stack</div>
          <ul class="tags">
            {stack.filter(Boolean).map((s) => <li class="tag">{s}</li>)}
          </ul>
        </div>
      )}

      {tags.length > 0 && (
        <div class="row">
          <div class="row__title">Tags</div>
          <ul class="tags">
            {tags.filter(Boolean).map((t) => <li class="tag">{t}</li>)}
          </ul>
        </div>
      )}

      {links.filter((l) => l?.label && l?.url).length > 0 && (
        <div class="links">
          {links
            .filter((l) => l?.label && l?.url)
            .map((l) => (
              <a class="link" href={l.url} target="_blank" rel="noopener">
                {l.label}
              </a>
            ))}
        </div>
      )}
    </div>

    <script is:inline>
      // Archived cards: expand/collapse ONLY via the top-right toggle button
      // Use event delegation so it works even if Astro hoists/bundles scripts.
      if (!window.__cvhubArchiveToggleBound) {
        window.__cvhubArchiveToggleBound = true;

        document.addEventListener('click', (e) => {
          const btn = e.target?.closest?.('.project__toggle');
          if (!btn) return;

          const card = btn.closest('article[data-archived="1"]');
          if (!card) return;

          e.preventDefault();
          e.stopPropagation();

          const isOpen = card.classList.toggle('is-open');
          card.classList.toggle('is-collapsed', !isOpen);
          btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }, true);
      }
    </script>
  </article>
) : (
  <article
    class={`card project project--${theme} ${featured ? 'project--featured' : ''} ${media.length === 0 ? 'project--no-media' : ''}`}
    style={accentStyle}
  >
    {featured && (
      <div class="project__pin" title="Featured" aria-label="Featured project">
        <svg class="project__pin-icon" viewBox="0 0 24 24" width="16" height="16" focusable="false" aria-hidden="true">
          <path d="M19.1835 7.80516L16.2188 4.83755C14.1921 2.8089 13.1788 1.79457 12.0904 2.03468C11.0021 2.2748 10.5086 3.62155 9.5217 6.31506L8.85373 8.1381C8.59063 8.85617 8.45908 9.2152 8.22239 9.49292C8.11619 9.61754 7.99536 9.72887 7.86251 9.82451C7.56644 10.0377 7.19811 10.1392 6.46145 10.3423C4.80107 10.8 3.97088 11.0289 3.65804 11.5721C3.5228 11.8069 3.45242 12.0735 3.45413 12.3446C3.45809 12.9715 4.06698 13.581 5.28476 14.8L6.69935 16.2163L2.22345 20.6964C1.92552 20.9946 1.92552 21.4782 2.22345 21.7764C2.52138 22.0746 3.00443 22.0746 3.30236 21.7764L7.77841 17.2961L9.24441 18.7635C10.4699 19.9902 11.0827 20.6036 11.7134 20.6045C11.9792 20.6049 12.2404 20.5358 12.4713 20.4041C13.0192 20.0914 13.2493 19.2551 13.7095 17.5825C13.9119 16.8472 14.013 16.4795 14.2254 16.1835C14.3184 16.054 14.4262 15.9358 14.5468 15.8314C14.8221 15.593 15.1788 15.459 15.8922 15.191L17.7362 14.4981C20.4 13.4973 21.7319 12.9969 21.9667 11.9115C22.2014 10.826 21.1954 9.81905 19.1835 7.80516Z" fill="currentColor"/>
        </svg>
      </div>
    )}
    <header class="card__header">
      <div>
        {(role || year) && (
          <div class="card__meta">
            {role && <span class="muted">{role}</span>}
            {year && <span class="muted">{role ? '· ' : ''}{year}</span>}
          </div>
        )}
        <h2 class="card__title">{title}</h2>
      </div>
    </header>

    {featuredMedia && (
      <div class="media">
        {featuredMedia.type === 'video' && (
          <video
            class="media__el"
            src={withBase(featuredMedia.src)}
            controls
            playsinline
            preload="metadata"
          ></video>
        )}

        {(featuredMedia.type === 'image' || featuredMedia.type === 'gif') && (
          <img
            class="media__el"
            src={withBase(featuredMedia.src)}
            alt={featuredMedia.alt ?? ''}
            loading="lazy"
            onerror="this.closest('.media')?.remove();"
          />
        )}

        {media.length > 1 && (
          <div class="thumbs" aria-label="Project media">
            {media.map((m, idx) => (
              <a
                class={`thumb ${m === featuredMedia ? 'thumb--active' : ''}`}
                href={withBase(m.src)}
                target="_blank"
                rel="noopener"
                title={m.alt ?? `Media ${idx + 1}`}
              >
                {(m.type === 'image' || m.type === 'gif') && (
                  <img
                    class="thumb__img"
                    src={withBase(m.src)}
                    alt={m.alt ?? ''}
                    loading="lazy"
                    onerror="this.closest('.thumb')?.remove();"
                  />
                )}
                {m.type === 'video' && (
                  <div class="thumb__video">▶</div>
                )}
              </a>
            ))}
          </div>
        )}
      </div>
    )}

    {desc && <p class="card__desc">{desc}</p>}

    {metrics.filter((m) => m?.label || m?.value).length > 0 && (
      <div class="metrics-grid">
        {metrics
          .filter((m) => m?.label || m?.value)
          .map((m) => (
            <div class="metric-card">
              {m.label && <div class="metric-label">{m.label}</div>}
              {m.value && <div class="metric-value">{m.value}</div>}
            </div>
          ))}
      </div>
    )}

    {platforms.length > 0 && (
      <div class="row">
        <div class="row__title">Platforms</div>
        <ul class="tags">
          {platforms.filter(Boolean).map((p) => <li class="tag">{p}</li>)}
        </ul>
      </div>
    )}

    {stack.length > 0 && (
      <div class="row">
        <div class="row__title">Stack</div>
        <ul class="tags">
          {stack.filter(Boolean).map((s) => <li class="tag">{s}</li>)}
        </ul>
      </div>
    )}

    {tags.length > 0 && (
      <div class="row">
        <div class="row__title">Tags</div>
        <ul class="tags">
          {tags.filter(Boolean).map((t) => <li class="tag">{t}</li>)}
        </ul>
      </div>
    )}

    {links.filter((l) => l?.label && l?.url).length > 0 && (
      <div class="links">
        {links
          .filter((l) => l?.label && l?.url)
          .map((l) => (
            <a class="link" href={l.url} target="_blank" rel="noopener">
              {l.label}
            </a>
          ))}
      </div>
    )}
  </article>
)}
