---
//
//  Layout.astro
//  CV Hub
//
//  Created by Alexander Gusarov on 03.03.2026.
//  @spartan121
//
import '../styles/global.css';
import AnimatedBackground from './AnimatedBackground.astro';




// Change theme here 
//    
//import '../styles/themes/vscode.css'; 
//
// Change theme here 

const { title = 'CV Hub', lang = 'en', section = 'main', description, ogImage } = Astro.props;

const siteUrl = 'https://keegooroomii.github.io/cv_hub';
const defaultDescription = lang === 'ru'
  ? 'Резюме Александра Гусарова — DevOps Engineer. Kubernetes, Terraform, AWS, CI/CD.'
  : 'Alexander Gusarov — DevOps Engineer. Kubernetes, Terraform, AWS, CI/CD.';
const defaultImage = `${siteUrl}/og-image.png`;

const metaDescription = description ?? defaultDescription;
const metaImage = ogImage ?? defaultImage;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const homeHref = `${base}/${lang === 'ru' ? 'ru' : ''}`;
const showcaseHref = `${base}/showcase${lang === 'ru' ? '/ru' : ''}`;

const data = {};

const currentYear = new Date().getFullYear();
const authorName = data?.name ?? 'Alexander Gusarov';
const authorGit = 'https://github.com/KeeGooRoomiE/cv_hub';

const otherLang = lang === 'ru' ? 'en' : 'ru';
const switchHref =
  section === 'showcase'
    ? `${base}/showcase${otherLang === 'ru' ? '/ru' : ''}`
    : `${base}/${otherLang === 'ru' ? 'ru' : ''}`;


---

<!doctype html>
<html lang={lang} data-base={base}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
      <meta name="description" content={metaDescription} />
      <link rel="canonical" href={canonicalUrl} />

      <!-- Open Graph -->
      <meta property="og:type" content="website" />
      <meta property="og:url" content={canonicalUrl} />
      <meta property="og:title" content={title} />
      <meta property="og:description" content={metaDescription} />
      <meta property="og:image" content={metaImage} />
      <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />

      <!-- Twitter Card -->
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={metaDescription} />
      <meta name="twitter:image" content={metaImage} />

      <script is:inline>
        const params = new URLSearchParams(window.location.search);
        const theme = params.get('theme');
        const allowed = ['frosted', 'light', 'nordic', 'peachy'];
        if (theme && allowed.includes(theme)) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = `${document.documentElement.dataset.base}/themes/${theme}.css`;
          document.addEventListener('DOMContentLoaded', () => {
            document.head.appendChild(link);
          });
        }
      </script>
  </head>
  <body>
  <AnimatedBackground />
    <header class="header">
      <div class="container header__row">
        <a class="brand" href={homeHref}>CV Hub</a>
        <nav class="nav">
          <a href={homeHref}>{lang === 'ru' ? 'Главная' : 'Home'}</a>
          <a href={showcaseHref}>{lang === 'ru' ? 'Шоукейс' : 'Showcase'}</a>
        </nav>
        <div class="lang">
          <a class={lang === 'en' ? 'active' : ''} href={switchHref.replace(/\/ru$/, '')}>EN</a>
          <a class={lang === 'ru' ? 'active' : ''} href={switchHref.endsWith('/ru') ? switchHref : `${switchHref}/ru`}>RU</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
    <div class="container footer__inner">
      <span>© {currentYear} {authorName}</span>
      <a href={authorGit} target="_blank" rel="noopener" class="footer__link">
        GitHub
      </a>
    </div>
  </footer>
  </body>
</html>