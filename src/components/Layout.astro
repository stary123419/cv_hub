---
//
//  Layout.astro
//  CV Hub
//
//  Created by Alexander Gusarov on 03.03.2026.
//  @spartan121
//
import '../styles/global.css';
import AnimatedBackground from './AnimatedBackground.astro';




// Change theme here 
//    
//import '../styles/themes/vscode.css'; 
//
// Change theme here 

const { title = 'CV Hub', lang = 'en', section = 'main' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const homeHref = `${base}/${lang === 'ru' ? 'ru' : ''}`;
const showcaseHref = `${base}/showcase${lang === 'ru' ? '/ru' : ''}`;

const data = {};

const currentYear = new Date().getFullYear();
const authorName = data?.name ?? 'Alexander Gusarov';
const authorGit = 'https://github.com/KeeGooRoomiE/cv_hub';

const otherLang = lang === 'ru' ? 'en' : 'ru';
const switchHref =
  section === 'showcase'
    ? `${base}/showcase${otherLang === 'ru' ? '/ru' : ''}`
    : `${base}/${otherLang === 'ru' ? 'ru' : ''}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
  <AnimatedBackground />
    <header class="header">
      <div class="container header__row">
        <a class="brand" href={homeHref}>CV Hub</a>
        <nav class="nav">
          <a href={homeHref}>{lang === 'ru' ? 'Главная' : 'Home'}</a>
          <a href={showcaseHref}>{lang === 'ru' ? 'Шоукейс' : 'Showcase'}</a>
        </nav>
        <div class="lang">
          <a class={lang === 'en' ? 'active' : ''} href={switchHref.replace(/\/ru$/, '')}>EN</a>
          <a class={lang === 'ru' ? 'active' : ''} href={switchHref.endsWith('/ru') ? switchHref : `${switchHref}/ru`}>RU</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
    <div class="container footer__inner">
      <span>© {currentYear} {authorName}</span>
      <a href={authorGit} target="_blank" rel="noopener" class="footer__link">
        GitHub
      </a>
    </div>
  </footer>
  </body>
</html>